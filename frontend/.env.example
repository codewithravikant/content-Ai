# Copy to .env. Never commit .env to git.
# Optional. If unset, the app uses same-origin `/api` (Vite dev proxy + nginx in Docker).
# **Railway / split hosts:** set this to your public backend URL before `npm run build`, e.g.
# VITE_API_BASE_URL=https://your-api.up.railway.app
# Local direct to backend:
# VITE_API_BASE_URL=http://localhost:8000
# Optional: must match backend GHOSTWRITER_CLIENT_API_KEY when that is set (visible in the browser bundle).
# VITE_CLIENT_API_KEY=
# Email login gate is controlled on the backend with GHOSTWRITER_REQUIRE_EMAIL_LOGIN (see backend/.env.example).
