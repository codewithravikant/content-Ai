# Copy to `.env` and fill in your values. Never commit `.env` to git.
#
# --- Local + Railway (same variable names) ---
# Do not paste secrets in chat or commit them. For hosted deploys, set these in Railway Variables.
#
# Example: Gmail SMTP (host must be smtp.gmail.com — not "stmp")
# | Variable              | Example / note |
# |-----------------------|----------------|
# | EMAIL_BACKEND         | smtp |
# | SMTP_HOST             | smtp.gmail.com |
# | SMTP_PORT             | 465 |
# | SMTP_USE_SSL          | 1 |
# | SMTP_USER             | youraccount@gmail.com |
# | SMTP_PASSWORD         | 16-character App Password (Google Account → Security → App passwords) |
# | SMTP_FROM or EMAIL_FROM | Content AI <youraccount@gmail.com>  OR  Content AI youraccount@gmail.com |
# Aliases: SMTP_PASS (= SMTP_PASSWORD). Port 587 + SMTP_USE_TLS=1 works without SSL wrapper.

# Logging: default is quiet (WARNING). Use LOG_LEVEL=INFO or DEBUG for verbose JSON logs.
# GHOSTWRITER_DEBUG=1 is shorthand for DEBUG when LOG_LEVEL is unset.
# LOG_LEVEL=WARNING

# --- Local AI (Ollama, LM Studio, etc.) ---
# Use your server IP/hostname — e.g. http://YOUR_SERVER_IP:8000/v1 or http://YOUR_SERVER_IP:11434/v1
#AI_SERVER_URL=http://YOUR_SERVER_IP:8000/v1
#AI_MODEL=llama3.1
#AI_PROVIDER=ollama  

# --- OpenAI (optional) ---
# OPENAI_API_KEY=sk-your_key_here

# --- Hugging Face (optional) ---
# HF_API_KEY=hf_your_token_here

# --- OpenRouter (required for cloud AI generation) ---
# Create a key at https://openrouter.ai/keys — never commit real keys to git.
OPENROUTER_API_KEY=
# Model id, e.g. openai/gpt-3.5-turbo or qwen/qwen3.6-plus:free (see README for OpenRouter model list)
OPENROUTER_MODEL=qwen/qwen3.6-plus:free

# --- Ghostwriter API security (optional) ---
# GHOSTWRITER_ENV=development
# production requires explicit CORS_ORIGINS (see README)
# With GHOSTWRITER_ENV=production, email sign-in is required by default for protected routes unless you set:
# GHOSTWRITER_REQUIRE_EMAIL_LOGIN=false
# GHOSTWRITER_CLIENT_API_KEY=
# Explicitly force email login in any environment: GHOSTWRITER_REQUIRE_EMAIL_LOGIN=true

# --- Email verification (optional; used with /auth/email/*) ---
# Default: SMTP to localhost:1025 (Mailpit / MailHog). Quick start: `make mailpit` (see `make email-help`)
# EMAIL_BACKEND=smtp
# SMTP_HOST=localhost
# SMTP_PORT=1025
# SMTP_FROM=ghostwriter@localhost
# Web UI link shown in the login modal (local Mailpit default):
# MAILPIT_WEB_URL=http://localhost:8025
# SMTP_USE_TLS=false
# SMTP_USER=
# SMTP_PASSWORD=
# Aliases: SMTP_PASS (same as SMTP_PASSWORD), EMAIL_FROM (same as SMTP_FROM).

# --- Uncomment and fill for Gmail (values stay in your local .env only) ---
# EMAIL_BACKEND=smtp
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=465
# SMTP_USE_SSL=1
# SMTP_USER=you@gmail.com
# SMTP_PASSWORD=
# SMTP_FROM=Content AI <you@gmail.com>

# Or use Resend (https://resend.com): you must set EMAIL_BACKEND=resend (not only RESEND_API_KEY),
# or the app defaults to SMTP (localhost) and mail will fail off your machine.
# EMAIL_BACKEND=resend
# RESEND_API_KEY=
# RESEND_FROM=onboarding@resend.dev
# Resend testing: you can usually only send TO your account email until you verify a domain and use From: your@domain.

# Optional secrets (set in production)
# EMAIL_AUTH_CODE_PEPPER=
# EMAIL_AUTH_CODE_TTL_SECONDS=600
# EMAIL_AUTH_SESSION_TTL_SECONDS=604800
# EMAIL_AUTH_SEND_IP_MAX=10
# EMAIL_AUTH_SEND_IP_WINDOW_SECONDS=900
# EMAIL_AUTH_SEND_EMAIL_MAX=5
# EMAIL_AUTH_SEND_EMAIL_WINDOW_SECONDS=3600
# EMAIL_AUTH_VERIFY_IP_MAX=30
# EMAIL_AUTH_VERIFY_IP_WINDOW_SECONDS=300
